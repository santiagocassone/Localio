@{
    var title       = ViewData["PageTitle"]       as string ?? "Localio";
    var description = ViewData["PageDescription"] as string ?? "";
    var keywords    = ViewData["PageKeywords"]    as string ?? "";
    var canonical   = ViewData["PageCanonical"]   as string ?? "";
    var ogImage     = ViewData["PageOgImage"]     as string ?? "/images/brand/localio-logo-horizontal-transparent.png";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content="@description" />
    @if (!string.IsNullOrEmpty(keywords))
    {
        <meta name="keywords" content="@keywords" />
    }

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content="Localio" />
    <meta property="og:title"       content="@title" />
    <meta property="og:description" content="@description" />
    @if (!string.IsNullOrEmpty(ogImage))
    {
        <meta property="og:image" content="@ogImage" />
    }
    @if (!string.IsNullOrEmpty(canonical))
    {
        <meta property="og:url" content="@canonical" />
        <link rel="canonical" href="@canonical" />
    }

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content="@title" />
    <meta name="twitter:description" content="@description" />
    @if (!string.IsNullOrEmpty(ogImage))
    {
        <meta name="twitter:image" content="@ogImage" />
    }

    <title>@title</title>

    <!-- Favicon -->
    <link rel="icon" href="/images/brand/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/images/brand/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/images/brand/favicon-64.png" />
    <link rel="apple-touch-icon" href="/images/brand/apple-touch-icon.png" />

    <!-- DM Sans — tipografía moderna y cercana -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700;9..40,800;9..40,900&display=swap"
          rel="stylesheet" />

    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />

    <partial name="_Clarity" />
</head>
<body class="landing-body">

    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>

    @RenderBody()

    <!-- Sticky CTA mobile — se muestra solo en pantallas pequeñas via CSS -->
    <div class="l-sticky-cta" aria-hidden="true">
        <a href="#contacto" aria-label="Consultar por WhatsApp">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Consultar por WhatsApp
        </a>
    </div>

    <script src="~/js/landing.js" asp-append-version="true"></script>
    <script src="~/js/localio-analytics.js" asp-append-version="true"></script>
</body>
</html>
