@using Localio.Web.Models
@using Localio.Web.Models.Modules
@using Localio.Web.Helpers
@model FeaturedServicesModuleConfig
@{
    var site  = ViewData["Site"]  as SiteConfig  ?? new SiteConfig();
    int delay = 0;
}

<section id="destacados"
         class="section @Model.CssClass"
         aria-labelledby="featured-title">
    <div class="container">

        <div class="section-header" data-animate>
            <span class="section-label">Especialidades</span>
            <h2 id="featured-title" class="section-title">@Model.Title</h2>
            @if (!string.IsNullOrEmpty(Model.Subtitle))
            {
                <p class="section-subtitle">@Model.Subtitle</p>
            }
        </div>

        <div class="grid-2" style="gap: 1.5rem;">
            @foreach (var service in Model.Items)
            {
                delay++;
                var waText = WhatsAppHelper.BuildUrl(
                    site.WhatsApp.Number,
                    WhatsAppHelper.BuildServiceMessage(site.BusinessName, service.Name));

                <article class="card featured-service" data-animate data-animate-delay="@Math.Min(delay, 4)">
                    <div class="featured-service-img">
                        @if (!string.IsNullOrEmpty(service.ImageUrl))
                        {
                            <img src="@service.ImageUrl"
                                 alt="@service.Name"
                                 style="width:100%;height:100%;object-fit:cover;"
                                 loading="lazy" />
                        }
                        else if (!string.IsNullOrEmpty(service.Icon))
                        {
                            <span aria-hidden="true">@service.Icon</span>
                        }
                    </div>
                    <div class="featured-service-body">
                        @if (service.Featured)
                        {
                            <span class="badge badge--accent mb-2">Destacado</span>
                        }
                        <h3 class="featured-service-name">@service.Name</h3>
                        @if (!string.IsNullOrEmpty(service.Description))
                        {
                            <p class="service-card-desc mt-2">@service.Description</p>
                        }
                        @if (!string.IsNullOrEmpty(service.Price))
                        {
                            <p class="service-card-price">@service.Price</p>
                        }
                        @if (!string.IsNullOrEmpty(site.WhatsApp.Number))
                        {
                            <div class="mt-3">
                                <a href="@waText"
                                   target="_blank"
                                   rel="noopener noreferrer"
                                   class="btn btn--primary btn--sm"
                                   data-wa-track="featured-@service.Name">
                                    Consultar precio
                                </a>
                            </div>
                        }
                    </div>
                </article>
            }
        </div>

    </div>
</section>
