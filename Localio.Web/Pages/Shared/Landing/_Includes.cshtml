@model Localio.Web.Pages.IndexModel
@{
    var includesItems = new[]
    {
        "Presentación del comercio",
        "Servicios principales",
        "Ubicación y mapa",
        "Botón de WhatsApp",
        "Horarios y datos de contacto",
        "Diseño responsive",
        "Secciones de confianza",
        "Preparado para crecer con el tiempo",
    };
}
<section class="section section--beige" id="que-incluye" aria-labelledby="includes-title">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">Qué puede incluir tu sitio</span>
            <h2 class="section-title" id="includes-title">
                Qué puede incluir tu sitio
            </h2>
            <p class="section-sub">
                Cada sitio se arma según el tipo de comercio, con las secciones que realmente importan.
            </p>
        </div>

        <ul class="l-includes__grid" aria-label="Contenido disponible">
            @foreach (var item in includesItems)
            {
                <li class="l-include-item">
                    <span class="l-include-item__check" aria-hidden="true">
                        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                    </span>
                    <span class="l-include-item__label">@item</span>
                </li>
            }
        </ul>
    </div>
</section>
