@model Localio.Web.Pages.IndexModel
<section class="section" id="que-hacemos" aria-labelledby="benefits-title">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">Lo que hacemos</span>
            <h2 class="section-title" id="benefits-title">
                Localio convierte esa información en una web simple, clara y profesional
            </h2>
            <p class="section-sub">
                Ordenamos lo importante de tu comercio en una página moderna: qué ofrecés, dónde estás,
                cómo contactarte y por qué elegirte.
            </p>
        </div>

        <div class="l-benefits__grid" role="list">
            <article class="l-benefit-card" role="listitem">
                <div class="l-benefit-card__ico" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                </div>
                <h3 class="l-benefit-card__title">Presencia profesional</h3>
                <p class="l-benefit-card__desc">
                    Una página clara y moderna para que tu negocio se vea confiable online.
                </p>
            </article>

            <article class="l-benefit-card" role="listitem">
                <div class="l-benefit-card__ico" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                </div>
                <h3 class="l-benefit-card__title">Contacto por WhatsApp</h3>
                <p class="l-benefit-card__desc">
                    Botones visibles para que los clientes te escriban fácil desde el celular.
                </p>
            </article>

            <article class="l-benefit-card" role="listitem">
                <div class="l-benefit-card__ico" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                </div>
                <h3 class="l-benefit-card__title">Información ordenada</h3>
                <p class="l-benefit-card__desc">
                    Servicios, ubicación, horarios y datos clave en una estructura simple.
                </p>
            </article>

            <article class="l-benefit-card" role="listitem">
                <div class="l-benefit-card__ico" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
                </div>
                <h3 class="l-benefit-card__title">Pensado para mobile</h3>
                <p class="l-benefit-card__desc">
                    Diseño responsive para que se vea bien desde el teléfono, que es como te van a buscar.
                </p>
            </article>
        </div>
    </div>
</section>
