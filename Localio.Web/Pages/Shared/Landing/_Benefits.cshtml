@model Localio.Web.Pages.IndexModel
<section class="section" id="beneficios" aria-labelledby="benefits-title">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">Por qué Localio</span>
            <h2 class="section-title" id="benefits-title">
                Tu comercio, mejor presentado en internet
            </h2>
            <p class="section-sub">
                Centralizamos la información importante de tu negocio en una web rápida,
                clara y profesional, lista para que te encuentren y te contacten.
            </p>
        </div>

        <div class="l-benefits__grid" role="list">
            <article class="l-benefit-card" role="listitem">
                <div class="l-benefit-card__ico" aria-hidden="true">✨</div>
                <h3 class="l-benefit-card__title">Mejor presencia online</h3>
                <p class="l-benefit-card__desc">
                    Tu comercio se ve profesional y genera una buena primera impresión en cualquier pantalla.
                </p>
            </article>

            <article class="l-benefit-card" role="listitem">
                <div class="l-benefit-card__ico" aria-hidden="true">🤝</div>
                <h3 class="l-benefit-card__title">Más confianza para nuevos clientes</h3>
                <p class="l-benefit-card__desc">
                    Un sitio ordenado transmite seriedad y ayuda a que clientes nuevos se animen a contactarte.
                </p>
            </article>

            <article class="l-benefit-card" role="listitem">
                <div class="l-benefit-card__ico" aria-hidden="true">📋</div>
                <h3 class="l-benefit-card__title">Información clara y ordenada</h3>
                <p class="l-benefit-card__desc">
                    Servicios, horarios, ubicación y precios en un solo lugar, fácil de navegar.
                </p>
            </article>

            <article class="l-benefit-card" role="listitem">
                <div class="l-benefit-card__ico" aria-hidden="true">💚</div>
                <h3 class="l-benefit-card__title">Contacto directo por WhatsApp</h3>
                <p class="l-benefit-card__desc">
                    Un botón visible en todo el sitio para que el cliente te escriba con un solo clic.
                </p>
            </article>

            <article class="l-benefit-card" role="listitem">
                <div class="l-benefit-card__ico" aria-hidden="true">📍</div>
                <h3 class="l-benefit-card__title">Ubicación con Google Maps</h3>
                <p class="l-benefit-card__desc">
                    Mapa integrado para que tus clientes lleguen sin complicaciones.
                </p>
            </article>

            <article class="l-benefit-card" role="listitem">
                <div class="l-benefit-card__ico" aria-hidden="true">📱</div>
                <h3 class="l-benefit-card__title">Adaptado a celulares</h3>
                <p class="l-benefit-card__desc">
                    Diseño responsive que se ve perfecto en cualquier dispositivo.
                </p>
            </article>

            <article class="l-benefit-card" role="listitem">
                <div class="l-benefit-card__ico" aria-hidden="true">🔎</div>
                <h3 class="l-benefit-card__title">Preparado para SEO local</h3>
                <p class="l-benefit-card__desc">
                    Estructura optimizada para que Google encuentre y muestre tu comercio en búsquedas locales.
                </p>
            </article>
        </div>
    </div>
</section>
