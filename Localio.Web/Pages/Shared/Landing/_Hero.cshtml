@model Localio.Web.Pages.IndexModel
<section class="l-hero" aria-labelledby="hero-title">
    <div class="container l-hero__inner">

        <div class="l-hero__content">
            <span class="section-tag">Sitios web para comercios locales</span>
            <h1 class="l-hero__title" id="hero-title">
                Sitios web <em>profesionales</em> para comercios locales
            </h1>
            <p class="l-hero__subtitle">
                Creamos páginas claras, modernas y adaptadas a tu negocio para que tus clientes
                encuentren tus servicios, horarios, ubicación y formas de contacto en un solo lugar.
            </p>

            <div class="l-hero__cta">
                <a href="#contacto" class="btn btn-primary btn-lg">
                    Consultá por tu sitio
                </a>
                <a href="@Localio.Web.Pages.IndexModel.TallyFormUrl"
                   class="btn btn-outline btn-lg"
                   target="_blank"
                   rel="noopener noreferrer"
                   aria-label="Pedí una evaluación de tu presencia online (abre en nueva pestaña)">
                    Pedí una evaluación de tu presencia online
                </a>
            </div>

            <p class="l-hero__badge" aria-label="Atención directa y personalizada">
                <span class="l-hero__badge-dot" aria-hidden="true"></span>
                Atención directa · Respuesta rápida · Sin intermediarios
            </p>
        </div>

        <!-- Mockup visual: representación de una web de comercio local -->
        <div class="l-hero__mockup" aria-hidden="true">
            <div class="l-mockup" role="img" aria-label="Ejemplo de sitio web para un comercio local">
                <!-- Barra de navegador -->
                <div class="l-mockup__bar">
                    <span class="l-mockup__dot l-mockup__dot--r"></span>
                    <span class="l-mockup__dot l-mockup__dot--y"></span>
                    <span class="l-mockup__dot l-mockup__dot--g"></span>
                    <span class="l-mockup__url">tucomercio.localio.com.ar</span>
                </div>

                <div class="l-mockup__body">
                    <!-- Hero band del comercio -->
                    <div class="l-mockup__hero-band">
                        <h3>Veterinaria San Martín</h3>
                        <p>Tu veterinaria de confianza en el barrio</p>
                        <span class="l-mockup__hero-btn">
                            <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                            Escribinos
                        </span>
                    </div>

                    <!-- Cards de servicios -->
                    <div class="l-mockup__cards">
                        <div class="l-mockup__card">
                            <div class="l-mockup__card-ico">🐾</div>
                            <div class="l-mockup__card-label">Consultas</div>
                        </div>
                        <div class="l-mockup__card">
                            <div class="l-mockup__card-ico">💉</div>
                            <div class="l-mockup__card-label">Vacunas</div>
                        </div>
                        <div class="l-mockup__card">
                            <div class="l-mockup__card-ico">✂️</div>
                            <div class="l-mockup__card-label">Peluquería</div>
                        </div>
                    </div>

                    <!-- Mapa + Horarios -->
                    <div class="l-mockup__row">
                        <div class="l-mockup__map">
                            <div class="l-mockup__map-grid"></div>
                            <div class="l-mockup__map-pin"></div>
                        </div>
                        <div class="l-mockup__hours">
                            <div class="l-mockup__hours-title">Horarios</div>
                            <div class="l-mockup__hour-row today">
                                <span>Lun–Vie</span><span>9–19h</span>
                            </div>
                            <div class="l-mockup__hour-row">
                                <span>Sábados</span><span>9–13h</span>
                            </div>
                            <div class="l-mockup__hour-row">
                                <span>Domingos</span><span>Cerrado</span>
                            </div>
                        </div>
                    </div>

                    <!-- WhatsApp flotante -->
                    <div class="l-mockup__wa-float">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                        Escribinos por WhatsApp
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>
