@model Localio.Web.Pages.IndexModel
<section class="l-hero" aria-labelledby="hero-title">
    <div class="container l-hero__inner">

        <div class="l-hero__content">
            <span class="l-hero__eyebrow">Sitios web para comercios locales</span>
            <h1 class="l-hero__title" id="hero-title">
                Una web profesional para que tu comercio se vea mejor y reciba más consultas
            </h1>
            <p class="l-hero__subtitle">
                Creamos sitios claros, modernos y orientados a WhatsApp para negocios físicos
                y profesionales locales.
            </p>

            <div class="l-hero__cta">
                <a href="@Model.WhatsAppUrl"
                   class="btn btn-wa btn-lg"
                   target="_blank"
                   rel="noopener noreferrer"
                   aria-label="Consultá por tu sitio por WhatsApp"
                   data-analytics-event="click_whatsapp">
                    <svg class="ico-wa" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    Consultá por tu sitio
                </a>
                <a href="@IndexModel.TallyFormUrl"
                   class="btn btn-outline btn-lg"
                   target="_blank"
                   rel="noopener noreferrer"
                   data-analytics-event="click_tally">
                    Pedí una evaluación de tu presencia online
                </a>
            </div>

            <div class="l-hero__badges">
                <span class="l-hero__badge-item">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    Pensado para comercios locales
                </span>
                <span class="l-hero__badge-item">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                    Diseño profesional
                </span>
                <span class="l-hero__badge-item">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    Contacto directo por WhatsApp
                </span>
            </div>
        </div>

        <!-- Mockup visual: representación del producto, no una captura real -->
        <div class="l-hero__mockup" aria-hidden="true">
            <div class="l-mockup" role="img" aria-label="Ejemplo de sitio web para un comercio local">
                <!-- Barra de navegador -->
                <div class="l-mockup__bar">
                    <span class="l-mockup__dot l-mockup__dot--r"></span>
                    <span class="l-mockup__dot l-mockup__dot--y"></span>
                    <span class="l-mockup__dot l-mockup__dot--g"></span>
                    <span class="l-mockup__url">tucomercio.localio.com.ar</span>
                </div>

                <div class="l-mockup__body">
                    <!-- Header ficticio del comercio -->
                    <div class="l-mockup__hero-band">
                        <h3>Tu comercio local</h3>
                        <p>Una web clara para que te encuentren y te contacten</p>
                        <span class="l-mockup__hero-btn">
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                            Escribinos
                        </span>
                    </div>

                    <!-- Tabs de navegación ficticias -->
                    <div class="l-mockup__nav">
                        <div class="l-mockup__nav-item active">
                            <svg viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
                            Servicios
                        </div>
                        <div class="l-mockup__nav-item">
                            <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            Ubicación
                        </div>
                        <div class="l-mockup__nav-item">
                            <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                            Contacto
                        </div>
                    </div>

                    <!-- Cards de servicios con íconos SVG -->
                    <div class="l-mockup__cards">
                        <div class="l-mockup__card">
                            <div class="l-mockup__card-ico">
                                <svg viewBox="0 0 24 24"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                            </div>
                            <div class="l-mockup__card-label">Consultas</div>
                        </div>
                        <div class="l-mockup__card">
                            <div class="l-mockup__card-ico">
                                <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                            </div>
                            <div class="l-mockup__card-label">Vacunas</div>
                        </div>
                        <div class="l-mockup__card">
                            <div class="l-mockup__card-ico">
                                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                            </div>
                            <div class="l-mockup__card-label">Peluquería</div>
                        </div>
                    </div>

                    <!-- Mapa + Horarios -->
                    <div class="l-mockup__row">
                        <div class="l-mockup__map">
                            <div class="l-mockup__map-grid"></div>
                            <div class="l-mockup__map-pin"></div>
                        </div>
                        <div class="l-mockup__hours">
                            <div class="l-mockup__hours-title">Horarios</div>
                            <div class="l-mockup__hour-row today">
                                <span>Lun–Vie</span><span>9–19h</span>
                            </div>
                            <div class="l-mockup__hour-row">
                                <span>Sábados</span><span>9–13h</span>
                            </div>
                            <div class="l-mockup__hour-row">
                                <span>Domingos</span><span>Cerrado</span>
                            </div>
                        </div>
                    </div>

                    <!-- WhatsApp flotante -->
                    <div class="l-mockup__wa-float">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                        Escribinos por WhatsApp
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>
