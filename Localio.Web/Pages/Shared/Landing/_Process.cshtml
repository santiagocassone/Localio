@model Localio.Web.Pages.IndexModel
<section class="section section--alt" id="proceso" aria-labelledby="process-title">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">Cómo trabajamos</span>
            <h2 class="section-title" id="process-title">
                Un proceso simple y acompañado
            </h2>
            <p class="section-sub">
                No necesitás saber de tecnología. Nosotros te guiamos en cada paso.
            </p>
        </div>

        <div class="l-process__steps">
            <article class="l-process-step">
                <div class="l-process-step__num" aria-label="Paso 1">1</div>
                <h3 class="l-process-step__title">Relevamos la información</h3>
                <p class="l-process-step__desc">
                    Hablamos con vos para entender tu comercio, tus servicios y lo que querés comunicar.
                </p>
            </article>

            <article class="l-process-step">
                <div class="l-process-step__num" aria-label="Paso 2">2</div>
                <h3 class="l-process-step__title">Organizamos el contenido</h3>
                <p class="l-process-step__desc">
                    Ordenamos textos, servicios, fotos y datos de contacto para que todo quede claro.
                </p>
            </article>

            <article class="l-process-step">
                <div class="l-process-step__num" aria-label="Paso 3">3</div>
                <h3 class="l-process-step__title">Diseñamos y armamos el sitio</h3>
                <p class="l-process-step__desc">
                    Construimos el sitio con un diseño profesional adaptado a tu tipo de comercio.
                </p>
            </article>

            <article class="l-process-step">
                <div class="l-process-step__num" aria-label="Paso 4">4</div>
                <h3 class="l-process-step__title">Revisamos y publicamos</h3>
                <p class="l-process-step__desc">
                    Revisamos juntos el resultado, hacemos ajustes y publicamos el sitio online.
                </p>
            </article>
        </div>
    </div>
</section>
