@model Localio.Web.Pages.IndexModel
<section class="section section--alt" id="proceso" aria-labelledby="process-title">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">Cómo funciona</span>
            <h2 class="section-title" id="process-title">
                Simple, rápido y sin complicarte
            </h2>
            <p class="section-sub">
                No necesitás saber de tecnología. Nosotros te guiamos en cada paso.
            </p>
        </div>

        <div class="l-process__steps">
            <article class="l-process-step">
                <div class="l-process-step__num" aria-label="Paso 1">1</div>
                <h3 class="l-process-step__title">Armamos un ejemplo</h3>
                <p class="l-process-step__desc">
                    Preparamos una primera versión con la información disponible de tu comercio.
                </p>
            </article>

            <article class="l-process-step">
                <div class="l-process-step__num" aria-label="Paso 2">2</div>
                <h3 class="l-process-step__title">Lo revisás</h3>
                <p class="l-process-step__desc">
                    Nos decís qué ajustar, corregir o mejorar. Sin límite de revisiones hasta que esté como vos querés.
                </p>
            </article>

            <article class="l-process-step">
                <div class="l-process-step__num" aria-label="Paso 3">3</div>
                <h3 class="l-process-step__title">Lo dejamos listo</h3>
                <p class="l-process-step__desc">
                    Publicamos una versión clara, profesional y orientada a recibir consultas.
                </p>
            </article>
        </div>
    </div>
</section>
