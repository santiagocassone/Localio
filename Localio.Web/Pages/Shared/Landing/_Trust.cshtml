@model Localio.Web.Pages.IndexModel
<section class="section section--dark" aria-labelledby="trust-title">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">Por qué Localio</span>
            <h2 class="section-title" id="trust-title">
                Pensado para negocios reales
            </h2>
            <p class="section-sub">
                No somos una plataforma masiva ni un constructor genérico.
                Trabajamos de cerca con cada comercio.
            </p>
        </div>

        <div class="l-trust__grid" role="list">
            <article class="l-trust-card" role="listitem">
                <span class="l-trust-card__ico" aria-hidden="true">🏘️</span>
                <h3 class="l-trust-card__title">Pensado para negocios reales</h3>
                <p class="l-trust-card__desc">
                    Cada sitio está adaptado al tipo de comercio, no es un template genérico sin contexto.
                </p>
            </article>

            <article class="l-trust-card" role="listitem">
                <span class="l-trust-card__ico" aria-hidden="true">⚡</span>
                <h3 class="l-trust-card__title">Sitios claros, rápidos y fáciles</h3>
                <p class="l-trust-card__desc">
                    Sin complejidades innecesarias: carga rápido, es fácil de navegar y fácil de mantener.
                </p>
            </article>

            <article class="l-trust-card" role="listitem">
                <span class="l-trust-card__ico" aria-hidden="true">🤙</span>
                <h3 class="l-trust-card__title">Comunicación directa</h3>
                <p class="l-trust-card__desc">
                    Hablás con quien hace el sitio. Sin intermediarios, sin formularios de soporte interminables.
                </p>
            </article>

            <article class="l-trust-card" role="listitem">
                <span class="l-trust-card__ico" aria-hidden="true">🚀</span>
                <h3 class="l-trust-card__title">Acompañamiento en la publicación</h3>
                <p class="l-trust-card__desc">
                    Te ayudamos a publicar el sitio y quedamos disponibles para ajustes iniciales.
                </p>
            </article>
        </div>
    </div>
</section>
