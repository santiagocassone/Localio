@model Localio.Web.Pages.IndexModel
<section class="section section--dark" aria-labelledby="trust-title">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">Por qué Localio</span>
            <h2 class="section-title" id="trust-title">
                Diseño claro, profesional y pensado para clientes reales
            </h2>
            <p class="section-sub">
                Cada sitio busca que la información importante sea fácil de encontrar,
                especialmente desde el celular: qué ofrecés, dónde estás y cómo contactarte.
            </p>
        </div>

        <div class="l-trust__grid" role="list">
            <article class="l-trust-card" role="listitem">
                <div class="l-trust-card__ico" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                </div>
                <h3 class="l-trust-card__title">Claridad</h3>
                <p class="l-trust-card__desc">
                    Toda la información importante de tu comercio organizada en una estructura simple y directa.
                </p>
            </article>

            <article class="l-trust-card" role="listitem">
                <div class="l-trust-card__ico" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <h3 class="l-trust-card__title">Confianza</h3>
                <p class="l-trust-card__desc">
                    Un sitio profesional transmite seriedad y ayuda a que nuevos clientes se animen a contactarte.
                </p>
            </article>

            <article class="l-trust-card" role="listitem">
                <div class="l-trust-card__ico" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
                </div>
                <h3 class="l-trust-card__title">Mobile first</h3>
                <p class="l-trust-card__desc">
                    La mayoría de tus clientes te van a buscar desde el celular. El sitio está pensado para eso.
                </p>
            </article>

            <article class="l-trust-card" role="listitem">
                <div class="l-trust-card__ico" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                </div>
                <h3 class="l-trust-card__title">Contacto directo</h3>
                <p class="l-trust-card__desc">
                    Botón de WhatsApp visible en todo el sitio para que el cliente te escriba con un solo toque.
                </p>
            </article>
        </div>
    </div>
</section>
