@model Localio.Web.Pages.IndexModel
<section class="section section--alt" id="para-quien" aria-labelledby="forwho-title">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">Para quién es</span>
            <h2 class="section-title" id="forwho-title">
                Ideal para todo tipo de comercio local
            </h2>
            <p class="section-sub">
                Trabajamos con negocios reales de barrio: desde consultorios hasta talleres.
                Si tenés un comercio y querés que tus clientes te encuentren online, Localio es para vos.
            </p>
        </div>

        <div class="l-forwho__grid" role="list">
            <article class="l-forwho-card" role="listitem">
                <span class="l-forwho-card__ico" aria-hidden="true">🐾</span>
                <h3 class="l-forwho-card__title">Veterinarias</h3>
                <p class="l-forwho-card__desc">
                    Mostrá tus servicios, horarios de atención, vacunatorio, peluquería canina y datos de contacto de forma clara.
                </p>
            </article>

            <article class="l-forwho-card" role="listitem">
                <span class="l-forwho-card__ico" aria-hidden="true">💆</span>
                <h3 class="l-forwho-card__title">Centros de estética</h3>
                <p class="l-forwho-card__desc">
                    Presentá tus tratamientos, galería de trabajos, precios y agendá consultas por WhatsApp.
                </p>
            </article>

            <article class="l-forwho-card" role="listitem">
                <span class="l-forwho-card__ico" aria-hidden="true">✂️</span>
                <h3 class="l-forwho-card__title">Peluquerías y barberías</h3>
                <p class="l-forwho-card__desc">
                    Publicá tus servicios, fotos del trabajo, horarios y recibí turnos directamente por WhatsApp.
                </p>
            </article>

            <article class="l-forwho-card" role="listitem">
                <span class="l-forwho-card__ico" aria-hidden="true">🔧</span>
                <h3 class="l-forwho-card__title">Talleres y servicios técnicos</h3>
                <p class="l-forwho-card__desc">
                    Explicá qué reparás, mostrá experiencia con fotos y facilitá el contacto para presupuestos.
                </p>
            </article>

            <article class="l-forwho-card" role="listitem">
                <span class="l-forwho-card__ico" aria-hidden="true">🩺</span>
                <h3 class="l-forwho-card__title">Consultorios profesionales</h3>
                <p class="l-forwho-card__desc">
                    Médicos, psicólogos, nutricionistas y más: informá tus especialidades, obra social y horarios.
                </p>
            </article>

            <article class="l-forwho-card" role="listitem">
                <span class="l-forwho-card__ico" aria-hidden="true">🏪</span>
                <h3 class="l-forwho-card__title">Comercios de barrio</h3>
                <p class="l-forwho-card__desc">
                    Panaderías, almacenes, tiendas de ropa, ferreterías y cualquier comercio que quiera estar en internet.
                </p>
            </article>
        </div>
    </div>
</section>
