@* Pantalla de demo no disponible — reutilizable en demos privadas.
   Incluir dentro del <body> de la página correspondiente.
   La página contenedora debe asegurar noindex/nofollow. *@
<main class="pdna-main" aria-label="Demo no disponible">
    <div class="pdna-card">
        <p class="pdna-icon" aria-hidden="true">&#128274;</p>
        <h1 class="pdna-title">Esta demo ya no se encuentra disponible.</h1>
        <a class="pdna-link" href="https://localio.com.ar/">Volver a Localio</a>
    </div>
</main>

<style>
    /* ── Demo no disponible — estilos inline para no depender de hojas externas ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body { background: #f5f5f5; font-family: system-ui, -apple-system, sans-serif; }

    .pdna-main {
        min-height: 100dvh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1.25rem;
    }

    .pdna-card {
        background: #ffffff;
        border-radius: 12px;
        padding: 2.5rem 2rem;
        max-width: 420px;
        width: 100%;
        text-align: center;
        box-shadow: 0 2px 16px rgba(0,0,0,.07);
    }

    .pdna-icon {
        font-size: 2.5rem;
        margin-bottom: 1.25rem;
        line-height: 1;
    }

    .pdna-title {
        font-size: 1.125rem;
        font-weight: 600;
        color: #1a1a1a;
        line-height: 1.4;
        margin-bottom: 1.75rem;
    }

    .pdna-link {
        display: inline-block;
        background: #1a1a1a;
        color: #ffffff;
        text-decoration: none;
        font-size: 0.9375rem;
        font-weight: 500;
        padding: 0.625rem 1.5rem;
        border-radius: 6px;
        transition: background 0.15s ease;
    }

    .pdna-link:hover { background: #333333; }

    @@media (prefers-color-scheme: dark) {
        body { background: #111111; }
        .pdna-card { background: #1e1e1e; box-shadow: 0 2px 16px rgba(0,0,0,.4); }
        .pdna-title { color: #f0f0f0; }
        .pdna-link { background: #f0f0f0; color: #111111; }
        .pdna-link:hover { background: #cccccc; }
    }
</style>
