@* ── Galería visual ──────────────────────────────────────────────────────── *@
<section class="pd-section pd-section--white" aria-labelledby="gallery-title">
    <div class="pd-container">
        <span class="pd-eyebrow">Imágenes</span>
        <h2 class="pd-section-title" id="gallery-title">Un espacio cercano para tu mascota</h2>
        <p class="pd-body-text pd-mb-md">
            Imágenes del espacio y la atención en Veterinaria Urquiza.
        </p>

        @* ── [GALERÍA DE FOTOS] ────────────────────────────────────────────────
           Reemplazar cada contenedor SVG placeholder por imágenes reales.
           Foto principal (vertical):
             <img src="~/images/demos/urquizavet/hero-veterinaria-urquiza.jpg"
                  alt="Exterior de Veterinaria Urquiza" loading="lazy" />
           Foto secundaria 1 (horizontal):
             <img src="~/images/demos/urquizavet/veterinaria-urquiza-mascota.jpg"
                  alt="Mascota atendida en Veterinaria Urquiza" loading="lazy" />
           Foto secundaria 2 (horizontal):
             <img src="~/images/demos/urquizavet/veterinaria-urquiza-detalle.jpg"
                  alt="Detalle del ambiente de Veterinaria Urquiza" loading="lazy" />
           ──────────────────────────────────────────────────────────────────── *@
        <div class="pd-gallery" aria-label="Imágenes del comercio" role="img">

            <div class="pd-gallery__main" aria-hidden="true">
                <svg viewBox="0 0 400 533" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%">
