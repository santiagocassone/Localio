@* ─ Header ─ *@
<header class="pd-header" role="banner">
    <div class="pd-header__inner">
        <a href="#inicio" class="pd-header__brand" aria-label="Ir al inicio — Veterinaria Urquiza">
            <span>Veterinaria Urquiza</span>
            <span class="pd-header__brand-sub">Villa Urquiza · CABA</span>
        </a>
        <nav class="pd-header__nav" aria-label="Navegación principal">
            <a class="pd-header__nav-link" href="#atencion">Servicios</a>
            <a class="pd-header__nav-link" href="#confianza">Confianza</a>
            <a class="pd-header__nav-link" href="#ubicacion">Ubicación</a>
            <a class="pd-header__nav-link" href="#contacto">Contacto</a>
        </nav>
        <div class="pd-header__cta">
            <a href="@Model.WhatsAppUrl"
               class="pd-btn pd-btn--wa"
               target="_blank"
               rel="noopener noreferrer"
               aria-label="Consultar por WhatsApp"
               data-analytics-event="click_whatsapp">
                <svg width="16" height="16" aria-hidden="true" focusable="false"><use href="#ic-whatsapp"/></svg>
                WhatsApp
            </a>
        </div>
    </div>
</header>

@* ─ Hero ─ *@
<section class="pd-hero" id="inicio" aria-labelledby="hero-title">
    <div class="pd-hero__inner">

        <div class="pd-hero__content-col">
            <div class="pd-hero__badges" aria-label="Datos destacados">
                <span class="pd-badge">
                    <svg width="12" height="12" aria-hidden="true"><use href="#ic-star"/></svg>
                    @UrquizaModel.Rating de calificación
                </span>
                <span class="pd-badge">
                    <svg width="12" height="12" aria-hidden="true"><use href="#ic-message"/></svg>
                    @UrquizaModel.ReviewsCount reseñas
                </span>
                <span class="pd-badge">
                    <svg width="12" height="12" aria-hidden="true"><use href="#ic-mappin"/></svg>
                    Villa Urquiza
                </span>
                <span class="pd-badge">
                    <svg width="12" height="12" aria-hidden="true"><use href="#ic-clock"/></svg>
                    Lun a sáb
                </span>
            </div>

            <span class="pd-eyebrow" aria-label="Categoría">Veterinaria en Villa Urquiza</span>

            <h1 class="pd-title" id="hero-title">Veterinaria Urquiza</h1>
            <p class="pd-subtitle">@UrquizaModel.BusinessTagline</p>
            <p class="pd-body-text pd-mb-md">
                Clínica médica, estudios, especialidades, farmacia veterinaria y artículos
                de petshop en un espacio cercano, profesional y fácil de contactar.
            </p>

            <div class="pd-btn-group">
                <a href="@Model.WhatsAppUrl"
                   class="pd-btn pd-btn--wa"
                   target="_blank"
                   rel="noopener noreferrer"
                   aria-label="Consultar por WhatsApp"
                   data-analytics-event="click_whatsapp">
                    <svg width="18" height="18" aria-hidden="true" focusable="false"><use href="#ic-whatsapp"/></svg>
                    Consultar por WhatsApp
                </a>
                <a href="@UrquizaModel.MapsUrl"
                   class="pd-btn pd-btn--outline"
                   target="_blank"
                   rel="noopener noreferrer"
                   aria-label="Cómo llegar a Veterinaria Urquiza"
                   data-analytics-event="click_maps">
                    <svg width="16" height="16" aria-hidden="true"><use href="#ic-navigation"/></svg>
                    Cómo llegar
                </a>
            </div>
        </div>

        @* ─ Panel visual hero (sin imagen) ─ *@
        <div class="pd-hero__photo-col" aria-hidden="true">
            <div class="pd-hero-panel">
                <div class="pd-hero-panel__label">Atención veterinaria local</div>
                <div class="pd-hero-panel__icons">
                    <div class="pd-hero-panel__icon-wrap pd-hero-panel__icon-wrap--lg">
                        <svg width="32" height="32" aria-hidden="true"><use href="#ic-stethoscope"/></svg>
                    </div>
                    <div class="pd-hero-panel__icon-wrap">
                        <svg width="24" height="24" aria-hidden="true"><use href="#ic-heartpulse"/></svg>
                    </div>
                    <div class="pd-hero-panel__icon-wrap">
                        <svg width="24" height="24" aria-hidden="true"><use href="#ic-paw"/></svg>
                    </div>
                </div>
                <div class="pd-hero-panel__title">Clínica · Estudios · Especialidades · Farmacia</div>
                <p class="pd-hero-panel__desc">
                    Servicios clínicos, especialidades, farmacia veterinaria y contacto
                    simple en un solo lugar.
                </p>
                <div class="pd-hero-panel__badges">
                    <span class="pd-badge">
                        <svg width="12" height="12" aria-hidden="true"><use href="#ic-star"/></svg>
                        @UrquizaModel.Rating de calificación
                    </span>
                    <span class="pd-badge">
                        <svg width="12" height="12" aria-hidden="true"><use href="#ic-message"/></svg>
                        @UrquizaModel.ReviewsCount reseñas
                    </span>
                    <span class="pd-badge">
                        <svg width="12" height="12" aria-hidden="true"><use href="#ic-mappin"/></svg>
                        Villa Urquiza
                    </span>
                    <span class="pd-badge">
                        <svg width="12" height="12" aria-hidden="true"><use href="#ic-badge-check"/></svg>
                        WhatsApp directo
                    </span>
                </div>
            </div>
        </div>

    </div>
</section>

@* ─ Confianza / Reputación ─ *@
<section class="pd-section pd-section--white" id="confianza" aria-labelledby="trust-title">
    <div class="pd-container">
        <span class="pd-eyebrow">Reputación</span>
        <h2 class="pd-section-title" id="trust-title">Una veterinaria de confianza en Villa Urquiza</h2>

        <div class="pd-trust-grid pd-trust-grid--4" role="list">

            <article class="pd-trust-card" role="listitem">
                <div class="pd-trust-card__icon" aria-hidden="true">
                    <svg width="22" height="22"><use href="#ic-star"/></svg>
                </div>
                <div class="pd-trust-card__body">
                    <div class="pd-trust-card__title">@UrquizaModel.Rating de calificación</div>
                    <p class="pd-trust-card__desc">Valoración destacada en búsquedas locales de Villa Urquiza.</p>
                </div>
            </article>

            <article class="pd-trust-card" role="listitem">
                <div class="pd-trust-card__icon" aria-hidden="true">
                    <svg width="22" height="22"><use href="#ic-message"/></svg>
                </div>
                <div class="pd-trust-card__body">
                    <div class="pd-trust-card__title">@UrquizaModel.ReviewsCount reseñas</div>
                    <p class="pd-trust-card__desc">Reputación construida con clientes del barrio a lo largo del tiempo.</p>
                </div>
            </article>

            <article class="pd-trust-card" role="listitem">
                <div class="pd-trust-card__icon" aria-hidden="true">
                    <svg width="22" height="22"><use href="#ic-instagram"/></svg>
                </div>
                <div class="pd-trust-card__body">
                    <div class="pd-trust-card__title">Instagram activo</div>
                    <p class="pd-trust-card__desc">Presencia visual y canales activos para novedades del comercio.</p>
                </div>
            </article>

            <article class="pd-trust-card" role="listitem">
                <div class="pd-trust-card__icon" aria-hidden="true">
                    <svg width="22" height="22"><use href="#ic-badge-check"/></svg>
                </div>
                <div class="pd-trust-card__body">
                    <div class="pd-trust-card__title">Contacto directo</div>
                    <p class="pd-trust-card__desc">Consultas fáciles y rápidas por WhatsApp, sin formularios.</p>
                </div>
            </article>

        </div>
    </div>
</section>

@* ─ Servicios veterinarios ─ *@
<section class="pd-section pd-section--alt" id="atencion" aria-labelledby="services-title">
    <div class="pd-container">
        <span class="pd-eyebrow">Atención</span>
        <h2 class="pd-section-title" id="services-title">Atención veterinaria integral</h2>
        <p class="pd-body-text pd-mb-md">
            Servicios clínicos, especialidades, estudios y farmacia para acompañar
            el cuidado de perros y gatos.
        </p>

        <div class="pd-services-grid pd-services-grid--3col" role="list">

            <article class="pd-service-card" role="listitem">
                <div class="pd-service-card__icon" aria-hidden="true">
                    <svg width="26" height="26"><use href="#ic-stethoscope"/></svg>
                </div>
                <h3 class="pd-service-card__title">Clínica médica</h3>
                <p class="pd-service-card__desc">Atención general, evaluación y orientación profesional para perros y gatos.</p>
            </article>

            <article class="pd-service-card" role="listitem">
                <div class="pd-service-card__icon" aria-hidden="true">
                    <svg width="26" height="26"><use href="#ic-heartpulse"/></svg>
                </div>
                <h3 class="pd-service-card__title">Cardiología</h3>
                <p class="pd-service-card__desc">Control y seguimiento de la salud cardiovascular.</p>
            </article>

            <article class="pd-service-card" role="listitem">
                <div class="pd-service-card__icon" aria-hidden="true">
                    <svg width="26" height="26"><use href="#ic-cross"/></svg>
                </div>
                <h3 class="pd-service-card__title">Cirugía</h3>
                <p class="pd-service-card__desc">Procedimientos quirúrgicos veterinarios.</p>
            </article>

            <article class="pd-service-card" role="listitem">
                <div class="pd-service-card__icon" aria-hidden="true">
                    <svg width="26" height="26"><use href="#ic-sparkles"/></svg>
                </div>
                <h3 class="pd-service-card__title">Dermatología</h3>
                <p class="pd-service-card__desc">Atención de piel, pelo, alergias y molestias dermatológicas.</p>
            </article>

            <article class="pd-service-card" role="listitem">
                <div class="pd-service-card__icon" aria-hidden="true">
                    <svg width="26" height="26"><use href="#ic-clipboard"/></svg>
                </div>
                <h3 class="pd-service-card__title">Endocrinología</h3>
                <p class="pd-service-card__desc">Evaluación y seguimiento de condiciones hormonales y metabólicas.</p>
            </article>

            <article class="pd-service-card" role="listitem">
                <div class="pd-service-card__icon" aria-hidden="true">
                    <svg width="26" height="26"><use href="#ic-scanline"/></svg>
                </div>
                <h3 class="pd-service-card__title">Radiología</h3>
                <p class="pd-service-card__desc">Estudios por imágenes para acompañar el diagnóstico veterinario.</p>
            </article>

            <article class="pd-service-card" role="listitem">
                <div class="pd-service-card__icon" aria-hidden="true">
                    <svg width="26" height="26"><use href="#ic-radar"/></svg>
                </div>
                <h3 class="pd-service-card__title">Ecografía</h3>
                <p class="pd-service-card__desc">Diagnóstico por imágenes complementario.</p>
            </article>

            <article class="pd-service-card" role="listitem">
                <div class="pd-service-card__icon" aria-hidden="true">
                    <svg width="26" height="26"><use href="#ic-activity"/></svg>
                </div>
                <h3 class="pd-service-card__title">Fisioterapia</h3>
                <p class="pd-service-card__desc">Acompañamiento para recuperación, movilidad y bienestar físico.</p>
            </article>

            <article class="pd-service-card" role="listitem">
                <div class="pd-service-card__icon" aria-hidden="true">
                    <svg width="26" height="26"><use href="#ic-pill"/></svg>
                </div>
                <h3 class="pd-service-card__title">Farmacia</h3>
                <p class="pd-service-card__desc">Farmacia veterinaria para acompañar tratamientos y cuidados indicados.</p>
            </article>

        </div>
    </div>
</section>

@* ─ Sobre Veterinaria Urquiza ─ *@
<section class="pd-section pd-section--beige" aria-labelledby="about-title">
    <div class="pd-container">
        <div class="pd-about-inner">

            <div>
                <span class="pd-eyebrow">Sobre nosotros</span>
                <h2 class="pd-section-title" id="about-title">Cercanía y atención profesional en el barrio</h2>
                <p class="pd-body-text pd-mb-md">
                    Veterinaria Urquiza acompaña el cuidado de perros y gatos en el barrio
                    con atención cercana, servicios clínicos, estudios complementarios,
                    especialidades, farmacia veterinaria y algunos artículos de petshop
                    para el cuidado diario.
                </p>

                <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.75rem;">
                    @foreach (var item in new[] {
                        "Atención veterinaria integral",
                        "Estudios y especialidades",
                        "Farmacia veterinaria",
                        "Artículos de petshop",
                        "Contacto directo por WhatsApp",
                        "Ubicación clara en Villa Urquiza"
                    })
                    {
                        <li style="display:flex;align-items:center;gap:0.625rem;font-size:0.9375rem;color:#1F2A2A;font-weight:500;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1F6F68" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                            @item
                        </li>
                    }
                </ul>
            </div>

            <div class="pd-about-visual" aria-hidden="true">
                <div class="pd-about-visual__row">
                    <div class="pd-about-visual__icon">
                        <svg width="20" height="20"><use href="#ic-mappin"/></svg>
                    </div>
                    <div>
                        <div class="pd-about-visual__label">Ubicación</div>
                        <div class="pd-about-visual__value">Villa Urquiza, CABA</div>
                    </div>
                </div>
                <div class="pd-about-visual__row">
                    <div class="pd-about-visual__icon">
                        <svg width="20" height="20"><use href="#ic-star"/></svg>
                    </div>
                    <div>
                        <div class="pd-about-visual__label">Calificación Google</div>
                        <div class="pd-about-visual__value">@UrquizaModel.Rating · @UrquizaModel.ReviewsCount reseñas</div>
                    </div>
                </div>
                <div class="pd-about-visual__row">
                    <div class="pd-about-visual__icon">
                        <svg width="20" height="20"><use href="#ic-instagram"/></svg>
                    </div>
                    <div>
                        <div class="pd-about-visual__label">Instagram</div>
                        <div class="pd-about-visual__value">@UrquizaModel.InstagramHandle</div>
                    </div>
                </div>
                <div class="pd-about-visual__row">
                    <div class="pd-about-visual__icon">
                        <svg width="20" height="20"><use href="#ic-clock"/></svg>
                    </div>
                    <div>
                        <div class="pd-about-visual__label">Horarios</div>
                        <div class="pd-about-visual__value" style="font-size:0.8125rem;">Lun–Vie · Sáb por la mañana</div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

@* ─ Petshop (secundario) ─ *@
<section class="pd-section pd-section--white" aria-labelledby="petshop-title">
