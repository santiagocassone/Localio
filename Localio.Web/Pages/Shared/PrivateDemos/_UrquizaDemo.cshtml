@* ============================================================
   Partial HTML de la demo privada: Veterinaria Urquiza.
   NO oficial. NO indexar. Demo generada por Localio para prospecto real.

   IMÁGENES: Los contenedores marcados con [FOTO] esperan imágenes reales.
   Cuando la demo avance, reemplazar los placeholders SVG por fotos reales
   autorizadas o validadas del comercio. Las rutas esperadas son:
     ~/images/demos/urquizavet/hero-veterinaria-urquiza.jpg
     ~/images/demos/urquizavet/veterinaria-urquiza-ambiente.jpg
     ~/images/demos/urquizavet/veterinaria-urquiza-mascota.jpg
     ~/images/demos/urquizavet/veterinaria-urquiza-detalle.jpg
   ============================================================ *@
@using Localio.Web.Pages.Demos
@model Localio.Web.Pages.Demos.UrquizaModel

@if (!Model.IsVisible)
{
    @await Html.PartialAsync("_DemoUnavailable")
    return;
}

