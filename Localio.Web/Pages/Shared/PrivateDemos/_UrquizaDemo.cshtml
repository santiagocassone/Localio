@* ── Sobre Veterinaria Urquiza ───────────────────────────────────────────── *@
<section class="pd-section pd-section--beige" aria-labelledby="about-title">
    <div class="pd-container">
        <div class="pd-about-inner">

            <div>
                <span class="pd-eyebrow">Sobre nosotros</span>
