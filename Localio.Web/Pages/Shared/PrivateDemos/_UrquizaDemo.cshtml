@* ============================================================
   Partial HTML de la demo privada: Veterinaria Urquiza.
   NO oficial. NO indexar. Demo generada por Localio para prospecto real.
   ============================================================ *@
@using Localio.Web.Pages.Demos
@model Localio.Web.Pages.Demos.UrquizaModel

@if (!Model.IsVisible)
{
    @await Html.PartialAsync("_DemoUnavailable")
    return;
}

