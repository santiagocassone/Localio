@* ─ Ubicación y contacto ─ *@
<section class="pd-section pd-section--sage" id="ubicacion" aria-labelledby="location-title"
         data-analytics-section="contact">
    <div class="pd-container">
        <span class="pd-eyebrow">Cómo llegar</span>
        <h2 class="pd-section-title" id="location-title">Estamos en Villa Urquiza</h2>

        <div class="pd-location-grid">

            <div class="pd-location-detail">

                <div class="pd-location-detail__row">
                    <div class="pd-location-detail__icon" aria-hidden="true">
                        <svg width="20" height="20"><use href="#ic-mappin"/></svg>
                    </div>
                    <div>
                        <div class="pd-location-detail__label">Dirección</div>
                        <div class="pd-location-detail__value">@UrquizaModel.Address</div>
                    </div>
                </div>

                @* ─ Horarios ─ *@
                <div class="pd-hours-card" style="margin-top:1.25rem;" aria-label="Horarios de atención">
                    <div class="pd-hours-card__header">
                        <svg width="16" height="16" aria-hidden="true"><use href="#ic-clock"/></svg>
                        Horarios de atención
                    </div>
                    <div class="pd-hours-card__row">
                        <div class="pd-hours-card__day">Lunes a viernes</div>
                        <div class="pd-hours-card__time">10:00 a 13:00 · 16:00 a 20:00</div>
                    </div>
                    <hr class="pd-hours-card__divider" />
                    <div class="pd-hours-card__row">
                        <div class="pd-hours-card__day">Sábados</div>
                        <div class="pd-hours-card__time">10:00 a 13:00</div>
                    </div>
                </div>

                <p class="pd-body-text" style="font-size:0.875rem;color:var(--c-text-muted);margin-top:1rem;">
                    También podés escribir por WhatsApp para consultar por artículos
                    de petshop disponibles.
                </p>

                <div class="pd-contact-btns" style="margin-top:1.25rem;">
                    <a href="@Model.WhatsAppUrl"
                       class="pd-contact-btn"
                       target="_blank"
                       rel="noopener noreferrer"
                       aria-label="Consultar por WhatsApp"
                       data-analytics-event="click_whatsapp">
                        <div class="pd-contact-btn__icon pd-contact-btn__icon--wa" aria-hidden="true">
                            <svg width="20" height="20"><use href="#ic-whatsapp"/></svg>
                        </div>
                        <div>
                            <div class="pd-contact-btn__label">WhatsApp</div>
                            <div class="pd-contact-btn__value">@UrquizaModel.WhatsAppDisplayText</div>
                        </div>
                    </a>

                    <a href="@UrquizaModel.MapsUrl"
                       class="pd-contact-btn"
                       target="_blank"
                       rel="noopener noreferrer"
                       aria-label="Cómo llegar en Google Maps"
                       data-analytics-event="click_maps">
                        <div class="pd-contact-btn__icon pd-contact-btn__icon--maps" aria-hidden="true">
                            <svg width="20" height="20"><use href="#ic-navigation"/></svg>
                        </div>
                        <div>
                            <div class="pd-contact-btn__label">Cómo llegar</div>
                            <div class="pd-contact-btn__value">Ver en Google Maps</div>
                        </div>
                    </a>

                    <a href="@UrquizaModel.InstagramUrl"
                       class="pd-contact-btn"
                       target="_blank"
                       rel="noopener noreferrer"
                       aria-label="Ver Instagram de Veterinaria Urquiza"
                       data-analytics-event="click_instagram">
                        <div class="pd-contact-btn__icon pd-contact-btn__icon--ig" aria-hidden="true">
                            <svg width="20" height="20"><use href="#ic-instagram"/></svg>
                        </div>
                        <div>
                            <div class="pd-contact-btn__label">Instagram</div>
                            <div class="pd-contact-btn__value">@UrquizaModel.InstagramHandle</div>
                        </div>
                    </a>
                </div>
            </div>

            <div class="pd-map-visual">
                <div class="pd-map-visual__header">
                    <div class="pd-map-visual__icon" aria-hidden="true">
                        <svg width="20" height="20"><use href="#ic-mappin"/></svg>
                    </div>
                    <div>
                        <div class="pd-map-visual__address-primary">@UrquizaModel.AddressShort</div>
                        <div class="pd-map-visual__address-secondary">Dr. Pedro Ignacio Rivera 5245</div>
                    </div>
                </div>
                <div class="pd-map-visual__detail">
                    <svg width="16" height="16" aria-hidden="true"><use href="#ic-star"/></svg>
                    @UrquizaModel.Rating de calificación · @UrquizaModel.ReviewsCount reseñas en Google
                </div>
                <a href="@UrquizaModel.MapsUrl"
                   class="pd-btn pd-btn--teal"
                   target="_blank"
                   rel="noopener noreferrer"
                   style="margin-top:0.5rem;"
                   data-analytics-event="click_maps">
                    <svg width="16" height="16" aria-hidden="true"><use href="#ic-navigation"/></svg>
                    Abrir en Google Maps
                </a>
            </div>

        </div>
    </div>
</section>

@* ─ CTA final ─ *@
<section class="pd-cta-section" id="contacto" aria-labelledby="cta-title">
    <div class="pd-cta-section__inner">
        <div class="pd-cta-section__icon" aria-hidden="true">
