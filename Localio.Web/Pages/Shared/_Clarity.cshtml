@* ── _Clarity.cshtml ────────────────────────────────────────────────────────
   Renderiza el script de Microsoft Clarity solo si está habilitado y el
   ProjectId está configurado. No renderiza nada en Development o si
   Enabled=false / ProjectId vacío.
   Activar en producción con variables de entorno:
     Analytics__Clarity__Enabled=true
     Analytics__Clarity__ProjectId=<id>
   ──────────────────────────────────────────────────────────────────────── *@
@using Microsoft.Extensions.Options
@using Localio.Web.Models
@inject IOptions<AnalyticsOptions> AnalyticsOpts
@{
    var clarity = AnalyticsOpts.Value.Clarity;
}
@if (clarity.Enabled && !string.IsNullOrWhiteSpace(clarity.ProjectId))
{
    <script type="text/javascript">
        (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", "@clarity.ProjectId");
    </script>
}
