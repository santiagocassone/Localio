@* ============================================================
   Demo privada para prospecto real: Veterinaria Citivet.
   NO publicar como sitio oficial. NO enlazar desde la landing publica.
   Acceso por URL directa: /demos/citivet
   o via subdominio:       citivet.localio.com.ar  (cuando EnableDemoSubdomains = true)
   El HTML de la demo esta en Pages/Shared/PrivateDemos/_CitivetDemo.cshtml.
   ============================================================ *@
@page "/demos/citivet"
@model Localio.Web.Pages.Demos.CitivetModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>@CitivetModel.PageTitle</title>
    <meta name="description" content="@CitivetModel.PageDescription" />
    @* Robots: noindex/nofollow para ActivePrivate, Draft y no disponibles; index/follow para ActivePublic y Converted. *@
    @if (Model.ShouldRenderNoIndex)
    {
        <meta name="robots" content="noindex, nofollow" />
    }
    <meta property="og:title"  content="@CitivetModel.PageTitle" />
    <meta property="og:type"   content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="~/css/private-demos.css" asp-append-version="true" />
    @* Clarity: no renderiza nada si esta deshabilitado *@
    @{ await Html.RenderPartialAsync("_Clarity"); }
</head>
<body class="pd-body">

@await Html.PartialAsync("PrivateDemos/_CitivetDemo", Model)

</body>
</html>